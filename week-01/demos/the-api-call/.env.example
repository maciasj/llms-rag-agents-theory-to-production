# Copy this file to .env and fill in your values.
# Every demo here needs just these three variables.

# OPENAI_ENDPOINT — base URL of any OpenAI-compatible API. The wire format is the
# same everywhere; only this line (and the key/model) change. Examples:
#   OpenAI:        https://api.openai.com/v1
#   OpenRouter:    https://openrouter.ai/api/v1
#   Groq:          https://api.groq.com/openai/v1
#   local Ollama:  http://localhost:11434/v1
OPENAI_ENDPOINT=https://api.openai.com/v1

# OPENAI_API_KEY — your key for that endpoint. (A local Ollama ignores it — any
# string works, e.g. "ollama".)
OPENAI_API_KEY=sk-your-key-here

# MODEL — the model name, spelled the way your provider spells it.
MODEL=gpt-4.1-mini

# Note: the multimodal/ demo needs a vision-capable MODEL (e.g. gpt-4.1-mini,
# gpt-4o) — point OPENAI_ENDPOINT at a provider that has one.
